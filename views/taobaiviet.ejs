<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h3 class="card-title mb-4">Tạo bài viết mới</h3>
        <form action="/news/tao" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Tiêu đề</label>
            <input type="text" name="tieuDe" class="form-control" required/>
          </div>
          <div class="mb-3">
            <label class="form-label">Mô tả ngắn</label>
            <textarea name="moTa" class="form-control" rows="3" placeholder="Nhập mô tả ngắn..."></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Thể loại</label>
            <select name="theLoai" class="form-select">
              <option value="Nghệ sĩ">Nghệ sĩ</option>
              <option value="Âm nhạc">Âm nhạc</option>
              <option value="Show">Show</option>
              <option value="Album">Album</option>
              <option value="Phim">Phim</option>
              <option value="Thể thao">Thể thao</option>
              <option value="Khác">Khác</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Ảnh minh họa</label>
            <input type="file" name="anhMinhHoa" class="form-control" accept="image/*" multiple/>
          </div>
          <div class="mb-3">
            <label class="form-label">Nội dung</label>
            <textarea name="noiDung" class="form-control" rows="10" required></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Đăng bài</button>
            <a href="/news" class="btn btn-outline-secondary">Hủy</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>