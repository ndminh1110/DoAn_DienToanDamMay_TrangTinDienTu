<div class="row">
  <div class="col-md-8">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/news">Trang chủ</a></li>
        <li class="breadcrumb-item active"><%= baiViet.tieuDe %></li>
      </ol>
    </nav>

    <span class="badge bg-secondary mb-2"><%= baiViet.theLoai %></span>
    <h1 class="mb-3"><%= baiViet.tieuDe %></h1>

    <p class="text-muted small">
      Tác giả: <strong><%= baiViet.tacGia?.ten %></strong> &bull;
      <%= new Date(baiViet.createdAt).toLocaleDateString('vi-VN') %> &bull;
      <%= baiViet.luotXem %> lượt xem
    </p>

    <div class="mb-2">
      <% if (baiViet.hashtags && baiViet.hashtags.length > 0) { %>
        <% baiViet.hashtags.forEach(tag => { %>
          <a href="/news?hashtag=<%= tag %>" class="hashtag-item">
            #<%= tag %>
          </a>
        <% }) %>
      <% } %>
    </div>

    <% if (session.success) { %>
      <script>alert('<%= session.success %>')</script>
    <% } %>

    <% if (baiViet.anhMinhHoa && baiViet.anhMinhHoa.length > 0) { %>
      <div class="row mb-3">
        <% baiViet.anhMinhHoa.forEach(anh => { %>
          <div class="col-md-6 mb-2">
            <img src="<%= anh %>" class="img-fluid rounded"/>
          </div>
        <% }) %>
      </div>
    <% } %>

    <div class="d-flex align-items-center gap-3 mb-3">
      <form action="/news/<%= baiViet._id %>/like" method="POST">
        <button type="submit" class="btn btn-sm <%= baiViet.luotThich.includes(session.MaNguoiDung) ? 'btn-danger' : 'btn-outline-danger' %>">
          ✨ <%= baiViet.luotThich.length %> Thích
        </button>
      </form>
    </div>

    <!-- Nút dịch ngôn ngữ -->
    <div class="d-flex align-items-center gap-2 mb-3">
      <span class="text-muted small">🌐 Dịch sang:</span>
      <button class="btn btn-outline-primary btn-sm" onclick="dichBai('en')">🇬🇧 Tiếng Anh</button>
      <button class="btn btn-outline-danger btn-sm" onclick="dichBai('zh')">🇨🇳 Tiếng Trung</button>
      <button class="btn btn-outline-warning btn-sm" onclick="dichBai('ja')">🇯🇵 Tiếng Nhật</button>
      <button class="btn btn-outline-success btn-sm" onclick="dichBai('ko')">🇰🇷 Tiếng Hàn</button>
      <button class="btn btn-outline-secondary btn-sm" onclick="khoiPhuc()">🔄 Gốc</button>
    </div>
    <div id="dichStatus" class="text-muted small mb-2" style="display:none">⏳ Đang dịch...</div>

    <!-- Nội dung hiển thị (có hashtag link) -->
    <div class="mt-3 mb-4">
      <p id="noiDungBai">
        <%- baiViet.noiDung.replace(/#(\w+)/g, '<a href="/news?hashtag=$1" class="hashtag-item">#$1</a>') %>
      </p>
    </div>

    <% if (session.MaNguoiDung && session.MaNguoiDung.toString() === baiViet.tacGia._id.toString()) { %>
      <div class="d-flex gap-2 mb-4">
        <a href="/news/<%= baiViet._id %>/sua" class="btn btn-warning btn-sm">Sửa bài</a>
        <a href="/news/<%= baiViet._id %>/xoa" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc muốn xóa bài này không?')">Xóa bài</a>
      </div>
    <% } %>

    <div class="mt-5">
      <h5 class="fw-bold mb-3">Bình luận (<%= dsBinhLuan.length %>)</h5>

      <% if (session.MaNguoiDung) { %>
      <% } else { %>
        <p class="text-muted"><a href="/auth/dangnhap">Đăng nhập</a> để bình luận.</p>
      <% } %>

      <% if (dsBinhLuan.length === 0) { %>
        <p class="text-muted">Chưa có bình luận nào.</p>
      <% } else { %>
        <% dsBinhLuan.forEach(bl => { %>
          <div class="card mb-2">
            <div class="card-body py-2">
              <div class="d-flex justify-content-between align-items-center">
                <span class="fw-semibold small"><%= bl.tacGia?.ten %></span>
                <span class="text-muted small"><%= new Date(bl.createdAt).toLocaleDateString('vi-VN') %></span>
              </div>
              <p class="mb-1 mt-1"><%= bl.noiDung %></p>
              <% if (session.MaNguoiDung && session.MaNguoiDung.toString() === bl.tacGia._id.toString()) { %>
                <a href="/binhluan/<%= bl._id %>/xoa" class="text-danger small" onclick="return confirm('Xóa bình luận này?')">Xóa</a>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <form action="/binhluan/<%= baiViet._id %>" method="POST" class="mb-4">
      <div class="mb-2">
        <textarea name="noiDung" class="form-control" rows="3" placeholder="Viết bình luận..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Gửi bình luận</button>
    </form>

    <a href="/news" class="btn btn-outline-secondary btn-sm">Quay lại</a>
  </div>

  <script>
  const noiDungGoc = document.getElementById('noiDungBai').innerHTML;
  const tieuDeGoc = document.querySelector('h1').innerText;

  async function dichBai(targetLang) {
    const status = document.getElementById('dichStatus');
    status.style.display = 'block';

    try {
      // Dịch tiêu đề
      const resTitle = await fetch('/dich/text', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: tieuDeGoc, targetLang, sourceLang: 'vi' })
      });
      const dataTitle = await resTitle.json();

      // Dịch nội dung
      const resContent = await fetch('/dich/text', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          text: document.getElementById('noiDungBai').innerText, 
          targetLang, 
          sourceLang: 'vi' 
        })
      });
      const dataContent = await resContent.json();

      document.querySelector('h1').innerText = dataTitle.translatedText;
      document.getElementById('noiDungBai').innerText = dataContent.translatedText;
    } catch (err) {
      alert('Dịch thất bại, thử lại sau!');
    } finally {
      status.style.display = 'none';
    }
  }

  function khoiPhuc() {
    document.querySelector('h1').innerText = tieuDeGoc;
    document.getElementById('noiDungBai').innerHTML = noiDungGoc;
  }
</script>

</div>
