                <li><hr class="dropdown-divider"/></li>
                <li><a class="dropdown-item text-warning" href="/admin">👑 Trang quản trị</a></li>
              <% } %>
              <li><hr class="dropdown-divider"/></li>
              <li><a class="dropdown-item text-danger" href="/auth/dangxuat">Đăng xuất</a></li>
            </ul>
