<h4 class="fw-bold mb-4">🛠️ Bảng điều khiển Admin</h4>

<!-- Thống kê -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm h-100">
      <div class="card-body py-4">
        <div class="fs-1 fw-bold text-warning"><%= choDuyet %></div>
        <div class="text-muted small mt-1">⏳ Chờ duyệt</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm h-100">
      <div class="card-body py-4">
        <div class="fs-1 fw-bold text-success"><%= daDuyet %></div>
        <div class="text-muted small mt-1">✅ Đã duyệt</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm h-100">
      <div class="card-body py-4">
        <div class="fs-1 fw-bold text-danger"><%= tuChoi %></div>
        <div class="text-muted small mt-1">❌ Từ chối</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card text-center border-0 shadow-sm h-100">
      <div class="card-body py-4">
        <div class="fs-1 fw-bold text-primary"><%= tongNguoiDung %></div>
        <div class="text-muted small mt-1">👤 Người dùng</div>
      </div>
    </div>
  </div>
</div>

<!-- Truy cập nhanh -->
<div class="row g-3">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <h5 class="fw-bold mb-2">📰 Quản lý bài viết</h5>
        <p class="text-muted small">Duyệt, từ chối hoặc xoá bài viết của người dùng.</p>
        <div class="d-flex gap-2 flex-wrap">
          <a href="/admin/baiviet?trangThai=choDuyet" class="btn btn-warning btn-sm">
            Chờ duyệt (<%= choDuyet %>)
          </a>
          <a href="/admin/baiviet" class="btn btn-outline-secondary btn-sm">Tất cả bài viết</a>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <h5 class="fw-bold mb-2">👥 Quản lý người dùng</h5>
        <p class="text-muted small">Xem danh sách, đổi vai trò hoặc xoá tài khoản.</p>
        <a href="/admin/nguoidung" class="btn btn-primary btn-sm">
          Xem người dùng (<%= tongNguoiDung %>)
        </a>
      </div>
    </div>
  </div>
</div>
